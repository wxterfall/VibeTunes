# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Text command prefix. This bot intentionally does not register slash commands.
COMMAND_PREFIX=!

# Embed branding
BOT_NAME=VibeTunes
EMBED_COLOR=C026D3
SUCCESS_COLOR=57F287
ERROR_COLOR=ED4245
WARNING_COLOR=FEE75C
NOW_PLAYING_UPDATE_SECONDS=10
SYNCED_LYRICS_ENABLED=true
SYNCED_LYRICS_PROVIDERS=
SYNCED_LYRICS_CONTEXT_LINES=1
SYNCED_LYRICS_OFFSET_SECONDS=0

# Spotify Developer Dashboard credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Genius token from https://genius.com/api-clients
GENIUS_TOKEN=your_genius_token

# Safety cap for Spotify playlists/albums.
MAX_SPOTIFY_TRACKS=100
